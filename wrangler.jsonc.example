{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "nekonymous",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-15",
  "workers_dev": true,
  "placement": {
    "mode": "smart"
  },
  "kv_namespaces": [
    {
      "binding": "NEKO_KV",
      "id": "REPLACE_ME"
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "nekonymous_core",
      "database_id": "REPLACE_ME",
      "migrations_dir": "migrations"
    }
  ],
  "queues": {
    "producers": [
      {
        "binding": "NEKO_OUTBOX_QUEUE",
        "queue": "neko-outbox"
      },
      {
        "binding": "NEKO_STATS_QUEUE",
        "queue": "neko-stats"
      },
      {
        "binding": "NEKO_DLQ",
        "queue": "neko-dlq"
      }
    ],
    "consumers": [
      {
        "queue": "neko-outbox",
        "max_batch_size": 10,
        "max_batch_timeout": 2,
        "max_retries": 5,
        "dead_letter_queue": "neko-dlq"
      },
      {
        "queue": "neko-stats",
        "max_batch_size": 50,
        "max_batch_timeout": 5,
        "max_retries": 5,
        "dead_letter_queue": "neko-dlq"
      }
    ]
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "USER_STATE_DO",
        "class_name": "UserStateDurableObject"
      },
      {
        "name": "TELEGRAM_OUTBOX_DO",
        "class_name": "TelegramOutboxDurableObject"
      },
      {
        "name": "TICKET_VAULT",
        "class_name": "TicketVaultDurableObject"
      },
      {
        "name": "REPORT_LEDGER",
        "class_name": "ReportLedgerDurableObject"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1-clean-core",
      "new_sqlite_classes": [
        "UserStateDurableObject",
        "TelegramOutboxDurableObject"
      ]
    },
    {
      "tag": "v2-delete-legacy-inbox",
      "deleted_classes": ["InboxSqliteDurableObject"]
    },
    {
      "tag": "v3-sealed-ticket-routing",
      "new_sqlite_classes": [
        "TicketVaultDurableObject",
        "ReportLedgerDurableObject"
      ]
    }
  ],
  "routes": [
    {
      "pattern": "nekonymous.mohetios.dev",
      "custom_domain": true
    }
  ],
  "ai": {
    "binding": "AI"
  },
  "vectorize": [
    {
      "binding": "PROFILE_VECTORS",
      "index_name": "nekonymous-profile-vectors"
    }
  ]
}
