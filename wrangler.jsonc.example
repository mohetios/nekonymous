{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "nekonymous",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-25",
  "workers_dev": true,
  "placement": {
    "mode": "smart"
  },
  "kv_namespaces": [
    {
      "binding": "NEKO_KV",
      "id": "REPLACE_ME"
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "nekonymous_core",
      "database_id": "REPLACE_ME",
      "migrations_dir": "migrations"
    }
  ],
  "queues": {
    "producers": [
      {
        "binding": "NEKO_OUTBOX_QUEUE",
        "queue": "neko-outbox"
      },
      {
        "binding": "NEKO_STATS_QUEUE",
        "queue": "neko-stats"
      },
      {
        "binding": "NEKO_DLQ",
        "queue": "neko-dlq"
      },
      {
        "binding": "NEKO_PROFILE_INDEX_QUEUE",
        "queue": "neko-profile-index"
      },
      {
        "binding": "NEKO_PROFILE_INDEX_DLQ",
        "queue": "neko-profile-index-dlq"
      }
    ],
    "consumers": [
      {
        "queue": "neko-outbox",
        "max_batch_size": 10,
        "max_batch_timeout": 2,
        "max_retries": 5,
        "dead_letter_queue": "neko-dlq"
      },
      {
        "queue": "neko-stats",
        "max_batch_size": 50,
        "max_batch_timeout": 5,
        "max_retries": 5,
        "dead_letter_queue": "neko-dlq"
      },
      {
        "queue": "neko-profile-index",
        "max_batch_size": 5,
        "max_batch_timeout": 5,
        "max_retries": 5,
        "dead_letter_queue": "neko-profile-index-dlq"
      }
    ]
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "USER_STATE_DO",
        "class_name": "UserStateDurableObjectV4"
      },
      {
        "name": "TELEGRAM_OUTBOX_DO",
        "class_name": "TelegramOutboxDurableObjectV4"
      },
      {
        "name": "TICKET_VAULT",
        "class_name": "TicketVaultDurableObjectV4"
      },
      {
        "name": "REPORT_LEDGER",
        "class_name": "ReportLedgerDurableObjectV4"
      },
      {
        "name": "PROFILE_VAULT_DO",
        "class_name": "ProfileVaultShardDurableObjectV2"
      },
      {
        "name": "CONVERSATION_VAULT_DO",
        "class_name": "ConversationVaultShardDurableObjectV2"
      },
      {
        "name": "PAIR_LEDGER_DO",
        "class_name": "PairLedgerShardDurableObjectV2"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1-clean-core",
      "new_sqlite_classes": [
        "UserStateDurableObject",
        "TelegramOutboxDurableObject"
      ]
    },
    {
      "tag": "v2-delete-legacy-inbox",
      "deleted_classes": ["InboxSqliteDurableObject"]
    },
    {
      "tag": "v3-sealed-ticket-routing",
      "new_sqlite_classes": [
        "TicketVaultDurableObject",
        "ReportLedgerDurableObject"
      ]
    },
    {
      "tag": "v4-create-reset-durable-objects",
      "new_sqlite_classes": [
        "UserStateDurableObjectV2",
        "TelegramOutboxDurableObjectV2",
        "TicketVaultDurableObjectV2",
        "ReportLedgerDurableObjectV2"
      ]
    },
    {
      "tag": "v5-delete-old-durable-objects",
      "deleted_classes": [
        "UserStateDurableObject",
        "TelegramOutboxDurableObject",
        "TicketVaultDurableObject",
        "ReportLedgerDurableObject"
      ]
    },
    {
      "tag": "v6-create-reset-durable-objects-v3",
      "new_sqlite_classes": [
        "UserStateDurableObjectV3",
        "TelegramOutboxDurableObjectV3",
        "TicketVaultDurableObjectV3",
        "ReportLedgerDurableObjectV3"
      ]
    },
    {
      "tag": "v7-delete-durable-objects-v2",
      "deleted_classes": [
        "UserStateDurableObjectV2",
        "TelegramOutboxDurableObjectV2",
        "TicketVaultDurableObjectV2",
        "ReportLedgerDurableObjectV2"
      ]
    },
    {
      "tag": "v8-conversation-v2-vault-shards",
      "new_sqlite_classes": [
        "ProfileVaultShardDurableObject",
        "ConversationVaultShardDurableObject",
        "PairLedgerShardDurableObject"
      ]
    },
    {
      "tag": "v9-create-reset-durable-objects-v4",
      "new_sqlite_classes": [
        "UserStateDurableObjectV4",
        "TelegramOutboxDurableObjectV4",
        "TicketVaultDurableObjectV4",
        "ReportLedgerDurableObjectV4",
        "ProfileVaultShardDurableObjectV2",
        "ConversationVaultShardDurableObjectV2",
        "PairLedgerShardDurableObjectV2"
      ]
    },
    {
      "tag": "v10-delete-durable-objects-v3-and-vault-v1",
      "deleted_classes": [
        "UserStateDurableObjectV3",
        "TelegramOutboxDurableObjectV3",
        "TicketVaultDurableObjectV3",
        "ReportLedgerDurableObjectV3",
        "ProfileVaultShardDurableObject",
        "ConversationVaultShardDurableObject",
        "PairLedgerShardDurableObject"
      ]
    }
  ],
  "vectorize": [
    {
      "binding": "CONVERSATION_VECTORS",
      "index_name": "nekonymous-conversation-v2"
    }
  ]
}
