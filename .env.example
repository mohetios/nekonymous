# Nekonymous local environment template
#
# Setup:
#   cp .env.example .dev.vars
#   Fill in real values.
#
# Wrangler (`pnpm dev`) loads secrets from `.dev.vars`.
# Never commit `.dev.vars`.

# Telegram Bot API token from @BotFather
SECRET_TELEGRAM_API_TOKEN=your-telegram-bot-token

# Random secret for Telegram webhook validation (X-Telegram-Bot-Api-Secret-Token)
BOT_SECRET_KEY=generate-a-random-string

# App-wide master key for payload/chat encryption (>= 32 bytes entropy)
APP_MASTER_KEY=generate-a-long-random-string

# HMAC pepper for Telegram user id hashing (>= 32 bytes entropy)
APP_HMAC_PEPPER=generate-another-long-random-string

# Cached JSON from https://api.telegram.org/bot<token>/getMe (result object only)
BOT_INFO={"id":0,"is_bot":true,"first_name":"Bot","username":"your_bot"}

# Display name used in bot copy
BOT_NAME=Nekonymous

# Telegram bot username without @, used for t.me deep links
BOT_USERNAME=your_bot

# Conversation V2 uses Wrangler bindings for Vectorize (8-d) and profile index queue.
# No Workers AI binding in V2.
