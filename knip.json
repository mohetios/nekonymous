{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "project": ["src/**/*.ts", "tools/**/*.{js,mjs,ts}", "test/**/*.ts"],
  "ignoreDependencies": ["cloudflare"],
  "ignoreFiles": [],
  "ignoreExportsUsedInFile": true,
  "ignoreIssues": {
    "src/index.ts": ["unlisted"],
    "src/i18n/labels.ts": ["exports"],
    "src/storage/profile-vault/**": ["files", "exports", "types"],
    "src/storage/conversation-vault/**": ["files", "exports", "types"],
    "src/storage/pair-ledger/**": ["files", "exports", "types"],
    "src/features/ticketing/conversation-keys.ts": ["exports", "types"],
    "src/features/conversation/profile/**": ["exports", "types"],
    "src/features/conversation/suggestions/**": ["files", "exports", "types"],
    "src/storage/user-state-client.ts": ["exports"],
    "src/features/ticketing/ticketing-service.ts": ["exports"],
    "src/bot/telegram-limits.ts": ["exports"]
  }
}
